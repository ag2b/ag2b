{
  "name": "@ag2b/react-chat",
  "version": "0.0.1",
  "description": "Drop-in chat UI for @ag2b/react",
  "license": "MIT",
  "author": "Alexey Vasyukov (@notmedia)",
  "homepage": "https://ag2b.ai",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@ag2b/core": "*",
    "@ag2b/react": "*",
    "react": ">=18",
    "react-dom": ">=18",
    "react-markdown": ">=9",
    "remark-gfm": ">=4"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.1",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "react-markdown": "9.0.1",
    "remark-gfm": "4.0.0",
    "vite": "8.0.14",
    "vite-plugin-dts": "5.0.1"
  }
}
