{
  "name": "@ag2b/react",
  "version": "0.0.1",
  "description": "AG2B bindings for React",
  "license": "MIT",
  "author": "Alexey Vasyukov (@notmedia)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@ag2b/core": "*",
    "react": ">=18",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "25.8.0",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "vite": "8.0.13",
    "vite-plugin-dts": "5.0.0"
  }
}
