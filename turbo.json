{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.js", "src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
    },
    "lint": {
      "inputs": ["src/**/*.js", "src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
    },
    "lint:fix": {
      "inputs": ["src/**/*.js", "src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
    },
    "test": {
      "inputs": ["src/**/*.js", "src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
    },
    "test:watch": {
      "inputs": ["src/**/*.js", "src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
    },
    "test:coverage": {
      "inputs": ["src/**/*.js", "src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"],
      "outputs": ["coverage/**"]
    }
  }
}
