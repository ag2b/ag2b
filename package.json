{
  "name": "ag2b",
  "version": "0.0.1",
  "description": "Agent to Browser - client-side agentic runtime.",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "ncu": "ncu -w --root -u",
    "commitlint": "commitlint"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@notmedia/eslint-config": "1.3.3",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "9.39.4",
    "lefthook": "2.1.8",
    "npm-check-updates": "22.2.0",
    "prettier": "3.8.3",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
